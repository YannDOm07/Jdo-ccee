generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Participant {
  id        String     @id @default(cuid())
  nom       String
  prenom    String
  telephone String
  email     String
  statut    Statut
  hash      String     @unique
  qrToken   String?    @unique
  createdAt DateTime   @default(now())
  promo     String?
  commandes Commande[]
  paiements Paiement[]
}

model Goodie {
  id          String     @id @default(cuid())
  nom         String
  description String
  prix        Int
  stock       Int
  imageUrl    String?
  tag         String?
  actif       Boolean    @default(true)
  commandes   Commande[]
}

model Commande {
  id            String         @id @default(cuid())
  participantId String
  article       String
  quantite      Int
  prix          Float
  statut        StatutPaiement @default(EN_ATTENTE)
  goodieId      String?
  goodie        Goodie?        @relation(fields: [goodieId], references: [id])
  participant   Participant    @relation(fields: [participantId], references: [id])
}

model Paiement {
  id            String         @id @default(cuid())
  participantId String
  montant       Float
  operateur     String
  transactionId String         @unique
  statut        StatutPaiement @default(EN_ATTENTE)
  createdAt     DateTime       @default(now())
  participant   Participant    @relation(fields: [participantId], references: [id])
}

enum Statut {
  ESATIC_CCEE
  ANCIEN
  EXTERNE
}

enum StatutPaiement {
  EN_ATTENTE
  PAYE
  ECHOUE
  REJETE
}
